{
  "name": "readable-stream-builder",
  "version": "0.0.3-alpha",
  "description": "Simple utility for sequentially constructing a Readable stream from sync and async sources.",
  "homepage": "https://github.com/cwins/readable-stream-builder#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cwins/readable-stream-builder.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "pnpm run test:node && pnpm run test:bun",
    "test:node": "vitest run --coverage __tests__/stream-builder.test.ts",
    "test:bun": "bunx --bun vitest run --coverage.enabled=false __tests__/stream-builder.test.ts",
    "examples:install": "cd examples && pnpm i --no-lockfile",
    "examples:clean": "cd examples && pnpm -r --include-workspace-root=true exec rm -rf node_modules",
    "examples:test": "cd examples && pnpm run test"
  },
  "keywords": [
    "streams",
    "streaming",
    "merge",
    "async",
    "ssr"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "peerDependencies": {
    "@types/node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
