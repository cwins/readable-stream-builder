{
  "name": "readable-stream-builder",
  "version": "0.0.2-alpha",
  "description": "Simple utility for sequentially constructing a Readable stream from sync and async sources.",
  "homepage": "https://github.com/cwins/readable-stream-builder#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cwins/readable-stream-builder.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "pnpm run test:node && pnpm run test:bun",
    "test:node": "pnpm run build && tsx --test __tests__/node/stream-builder.test.ts",
    "test:bun": "pnpm run build && bun test __tests__/bun/stream-builder.test.ts",
    "coverage": "pnpm run build && c8 --reporter=lcov --include dist/index.js tsx --test __tests__/node/stream-builder.test.ts",
    "test:examples": "tsx scripts/test-examples.ts"
  },
  "keywords": ["streams", "streaming", "merge", "async", "ssr"],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "peerDependencies": {
    "@types/node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "c8": "^7.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
